# ── LINE ──────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# ── AI (OpenAI) ───────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
# Model to use — gpt-4o recommended for accuracy
OPENAI_MODEL=gpt-4o

# ── Lark / Feishu ─────────────────────────────────────
LARK_APP_ID=your_lark_app_id
LARK_APP_SECRET=your_lark_app_secret
# The user_id or open_id that will be set as task collaborator/assignee
LARK_ASSIGNEE_USER_ID=your_lark_user_id

# ── App ───────────────────────────────────────────────
PORT=3000
# Business hours in Asia/Bangkok (UTC+7)
BUSINESS_HOUR_START=9
BUSINESS_HOUR_END=18
